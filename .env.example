# Point at the SAME Mongo the Python version uses (or a dev copy for the comparison).
# NEVER put real credentials in git — copy this to .env.local and fill it in there.
MONGO_URI=mongodb://localhost:27017
MONGO_DB=event_tracker

# Session signing secret. Generate a long random value (>=16 chars). Also derives the TOTP-secret
# at-rest wrap key, the WebAuthn/calendar challenge-token HMAC, and the OAuth flow-cookie signature —
# losing it invalidates all sessions + TOTP-at-rest + calendar feed tokens.
ET_SESSION_SECRET=change-me-to-a-long-random-string

# Public base URL (https://host[:port]). Used for the WebAuthn RP ID / expected origin (passkeys) and
# the absolute calendar-feed URLs. Defaults: RP ID 'localhost' + the request origin when unset (dev).
# EIT_PUBLIC_URL=https://events.example.com

# Google OAuth (OIDC) sign-in. A verified Google email binds to the SAME directory account as a
# local password (email is the identity key); a new email is provisioned read-only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: restrict SSO to these email domains (comma/space separated). Empty = open.
# EIT_OIDC_ALLOWED_DOMAINS=
# Deploy-time admin allowlist — always admin, can't be demoted by a directory write.
# EIT_ADMIN_EMAILS=
