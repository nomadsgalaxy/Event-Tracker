# Copy to .env.local (dev) or your container env (prod). NEVER commit real values.
# Full reference: docs/SETUP.md

# --- Core (required) ---
# MongoDB connection string. A standalone mongod is fine (no replica set needed).
MONGO_URI=mongodb://localhost:27017
MONGO_DB=event_tracker

# Session signing secret, >=16 chars. Generate: openssl rand -hex 32
# Also derives at-rest encryption for integration keys, TOTP, passkey/calendar/OAuth tokens.
# Rotating it logs everyone out and makes stored encrypted keys unrecoverable.
ET_SESSION_SECRET=change-me-to-a-long-random-string

# --- Public URL (set this behind a reverse proxy) ---
# Pins the OAuth redirect_uri, passkey origin, and calendar feed URLs.
# EIT_PUBLIC_URL=https://events.example.com

# --- Auth & access ---
# Always-admin emails (comma/space separated); cannot be demoted by a directory write.
# EIT_ADMIN_EMAILS=admin@example.com

# Google sign-in (OIDC). Set both to enable; add the redirect URI
# https://your-domain.example/api/auth/google/callback to the OAuth client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Restrict SSO to these email domains (comma/space separated). Empty = open (new emails land read-only).
# EIT_OIDC_ALLOWED_DOMAINS=example.com

# --- Deployment tenant (Data Matrix) ---
# Hashed into every Data Matrix label. Defaults to the first user's email domain, else MONGO_DB.
# Pin it only if you have already printed labels and want it fixed. See docs/SETUP.md.
# EIT_TENANT_ID=example.com

# --- Integration keys (all optional; env overrides the in-app Config store) ---
# GOOGLE_API_KEY=                 # Places autocomplete + venue weather
# FLIGHTAWARE_API_KEY=            # flight lookup + delay alerts (FlightAware AeroAPI)
# OPENSKY_CLIENT_ID=              # OpenSky API client (live flight progress)
# OPENSKY_CLIENT_SECRET=
# EASYPOST_API_KEY=               # shipment tracking
# AFTERSHIP_API_KEY=              # AfterShip / UniShippers tracking
# SEVENTEENTRACK_API_KEY=         # 17TRACK free-tier tracking

# --- Build / version (set in CI/Docker) ---
# BUILD_ID=                       # e.g. the git short SHA; drives auto-reload after deploy

# --- Demo mode (public self-resetting sandbox) ---
# EIT_DEMO_MODE=1
# EIT_DEMO_USER=demo@example.com
